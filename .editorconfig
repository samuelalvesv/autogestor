# ==========================================================================
# 22. DESABILITAR CA2007 PARA PROJETOS DE APLICAÇÃO (não-library)
# ==========================================================================
# CA2007 (ConfigureAwait) é relevante apenas para libraries.
# Pode ser desabilitado individualmente em projetos de aplicação via .editorconfig
# local ou via <NoWarn> no .csproj. Mantido como warning aqui para libraries.

# ==========================================================================
# 23. MIGRATIONS (EF CORE)
# ==========================================================================
# Desabilita a análise de estilo, formatação e verificação de charset
# para os arquivos de migrations gerados pelo Entity Framework Core.
[**/Migrations/**.cs]
generated_code = true
charset = unset
