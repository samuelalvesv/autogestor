<Router AppAssembly="@typeof(Autogestor.UI._Imports).Assembly"
        AdditionalAssemblies="new[] { typeof(App).Assembly }"
        NotFoundPage="typeof(Autogestor.UI.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Autogestor.UI.Layout.MainLayout)"/>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
</Router>
